# ====================================================================
# GreenCo Platform - Global Gitignore Configurations
# ====================================================================

# 1. Maven & Java Compilation Files
target/
*.class
*.jar
*.war
*.ear
.mvn/
.metadata/
.classpath
.project
.settings/
*.log
logs/

# 2. NodeJS & React Bundle Files
node_modules/
dist/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 3. Environment Config Keys & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 4. OS & IDE Specific Cache Folders
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# 5. Local Docker Data Storage (if mounted in subfolders)
greenco-uploads/
mysql-data/
redis-data/
minio-data/
rabbitmq-data/
