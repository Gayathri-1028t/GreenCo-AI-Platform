# ====================================================================
# GreenCo Backend Environment Variables Template
# Copy this file to .env and replace placeholders with credentials
# ====================================================================

# 1. Database Configurations
DB_HOST=localhost
DB_PORT=3306
DB_NAME=greenco_db
DB_USER=root
DB_PASSWORD=your_secure_password_here

# 2. JWT Configurations
# Generate a secure HS256 hex secret key (at least 256 bits / 64 characters)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# 3. Redis Configurations
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# 4. AWS S3 Bucket Storage Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=greenco-evidence-vault

# 5. AI OCR Microservice Integration
AI_SERVICE_ENDPOINT=http://localhost:5000/api/v1/ai
AI_SERVICE_API_KEY=your_ai_ocr_key_here

# 6. SMTP Email Server Settings
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_smtp_provider_apikey_here
