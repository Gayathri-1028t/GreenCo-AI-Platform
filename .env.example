# ====================================================================
# GreenCo Platform - Global Environment Variable Templates
# Copy this template to .env inside your workspace root
# ====================================================================

# 1. MySQL Database Secrets
DB_HOST=localhost
DB_PORT=3306
DB_NAME=greenco_db
DB_USER=root
DB_PASSWORD=rootpassword

# 2. JWT Tokens configuration
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# 3. Redis Cache Host
REDIS_HOST=localhost
REDIS_PORT=6379

# 4. AWS S3 / MinIO Object Storage Configurations
AWS_S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=greenco-documents-bucket
AWS_REGION=us-east-1

# 5. RabbitMQ Broker Credentials
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# 6. AI OCR Service parameters
AI_SERVICE_ENDPOINT=http://localhost:5000/api/v1/ai
AI_SERVICE_API_KEY=mock-key

# 7. Frontend Vite Configurations
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_NAME=GreenCo Sustainability Platform
VITE_UPLOAD_LIMIT_MB=25
